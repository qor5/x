{
  "name": "vuetifyxjs",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "comp": "npx tsx ./scripts/new-demo-doc.ts",
    "dev": "vitepress dev docs",
    "build": "vue-tsc --noEmit && vite build ",
    "build:lib": "cross-env NODE_ENV=lib babel src --out-dir lib --source-maps --extensions \".ts\",\".tsx\",\".snap\" --copy-files --no-copy-ignored --out-file-extension .mjs",
    "watch-build": "nodemon --watch src --ext ts,scss,vue --exec 'npm run build'",
    "preview": "vite preview",
    "format": "prettier --write src/",
    "test:unit": "vitest",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --port 8080"
  },
  "dependencies": {
    "@mdi/font": "7.4.47",
    "@tiptap/core": "^2.27.2",
    "@tiptap/vue-3": "^2.27.2",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vueuse/core": "^11.3.0",
    "date-fns": "^3.6.0",
    "dayjs": "^1.11.20",
    "dompurify": "^3.4.1",
    "echarts": "^5.6.0",
    "lodash": "^4.18.1",
    "resize-observer-polyfill": "^1.5.1",
    "roboto-fontface": "^0.10.0",
    "vue-i18n": "9.14.5",
    "vue-json-pretty": "^2.6.0",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.12.5",
    "vuetify-pro-tiptap": "github:qor5/vuetify-pro-tiptap"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@docsearch/css": "^3.9.0",
    "@docsearch/js": "^3.9.0",
    "@types/jsdom": "^21.1.7",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.19.39",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitepress-code-preview/container": "1.0.8",
    "@vitepress-code-preview/plugin": "^1.0.6",
    "@vue/test-utils": "^2.4.6",
    "body-scroll-lock": "4.0.0-beta.0",
    "cross-env": "^7.0.3",
    "inquirer": "^12.11.1",
    "jsdom": "^27.4.0",
    "msw": "^2.13.5",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "sass-loader": "14.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "unplugin-fonts": "^1.4.0",
    "unplugin-vue-components": "0.26.0",
    "vite": "7.1.5",
    "vite-plugin-vuetify": "^2.1.3",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4",
    "vue": "^3.5.33",
    "vue-tsc": "^2.2.12"
  },
  "pnpm": {
    "patchedDependencies": {
      "@vitepress-code-preview/container": "patches/@vitepress-code-preview__container.patch"
    },
    "overrides": {
      "esbuild": "0.25.0"
    }
  },
  "engines": {
    "pnpm": "10.16.1"
  },
  "packageManager": "pnpm@10.16.1+sha512.0e155aa2629db8672b49e8475da6226aa4bdea85fdcdfdc15350874946d4f3c91faaf64cbdc4a5d1ab8002f473d5c3fcedcd197989cf0390f9badd3c04678706"
